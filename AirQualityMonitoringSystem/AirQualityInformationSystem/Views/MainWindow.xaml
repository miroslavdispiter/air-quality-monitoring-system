<Window x:Class="AirQualityInformationSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:vm="clr-namespace:AirQualityInformationSystem.ViewModels"
        xmlns:local="clr-namespace:AirQualityInformationSystem.Views"
        mc:Ignorable="d"
        Title="Air Quality Information System" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Menu Bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Save Data" Command="{Binding SaveDataCommand}" Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Load Data" Command="{Binding LoadDataCommand}" Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Undo" Command="{Binding UndoCommand}" Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Redo" Command="{Binding RedoCommand}" Padding="10,5" Margin="0,0,5,0"/>
        </StackPanel>

        <!-- Main Content -->
        <TabControl Grid.Row="1">

            <!-- Monitoring Stations Tab -->
            <TabItem Header="Monitoring Stations">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search Bar -->
                    <GroupBox Header="Search Stations" Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding StationSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="300" Margin="5"/>
                            <TextBlock Text="Search by: Name, City, District, Latitude, Longitude" 
                                       VerticalAlignment="Center" Margin="10,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Stations List -->
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding FilteredStations}" 
                              SelectedItem="{Binding SelectedStation}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="250" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
                            <DataGridTextColumn Header="District" Binding="{Binding District}" Width="*"/>
                            <DataGridTextColumn Header="Latitude" Binding="{Binding Latitude}" Width="100"/>
                            <DataGridTextColumn Header="Longitude" Binding="{Binding Longitude}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Add/Update/Delete Station -->
                    <GroupBox Header="Station Management" Grid.Row="2">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Name:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewStationName, UpdateSourceTrigger=PropertyChanged}" 
                                         Grid.Row="0" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="City:" Grid.Row="0" Grid.Column="2" Margin="5" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewStationCity, UpdateSourceTrigger=PropertyChanged}" 
                                         Grid.Row="0" Grid.Column="3" Margin="5"/>

                                <TextBlock Text="District:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewStationDistrict, UpdateSourceTrigger=PropertyChanged}" 
                                         Grid.Row="1" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="Latitude:" Grid.Row="1" Grid.Column="2" Margin="5" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewStationLatitude, UpdateSourceTrigger=PropertyChanged}" 
                                         Grid.Row="1" Grid.Column="3" Margin="5"/>

                                <TextBlock Text="Longitude:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewStationLongitude, UpdateSourceTrigger=PropertyChanged}" 
                                         Grid.Row="2" Grid.Column="1" Margin="5"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="Add Station" Command="{Binding AddStationCommand}" 
                                        Padding="10,5" Margin="0,0,5,0"/>
                                <Button Content="Update Selected" Command="{Binding UpdateStationCommand}" 
                                        Padding="10,5" Margin="0,0,5,0"/>
                                <Button Content="Delete Selected" Command="{Binding DeleteStationCommand}" 
                                        Padding="10,5"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Air Quality Readings Tab -->
            <TabItem Header="Air Quality Readings">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search Bar -->
                    <GroupBox Header="Search Readings" Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding ReadingSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="300" Margin="5"/>
                            <TextBlock Text="Search by: StationId, Time, PM2.5, NO2, Ozone, State" 
                                       VerticalAlignment="Center" Margin="10,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Readings List -->
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding FilteredReadings}" 
                              SelectedItem="{Binding SelectedReading}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="200" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Station ID" Binding="{Binding StationId}" Width="200"/>
                            <DataGridTextColumn Header="Reading Time" Binding="{Binding ReadingTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150"/>
                            <DataGridTextColumn Header="PM2.5" Binding="{Binding PM25, StringFormat=F2}" Width="80"/>
                            <DataGridTextColumn Header="NO2" Binding="{Binding NO2Level, StringFormat=F2}" Width="80"/>
                            <DataGridTextColumn Header="Ozone" Binding="{Binding OzoneLevel, StringFormat=F2}" Width="80"/>
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Add/Update/Delete Reading -->
                    <GroupBox Header="Reading Management" Grid.Row="2">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Station ID:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewReadingStationId, UpdateSourceTrigger=PropertyChanged}" 
                                         Grid.Row="0" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="Reading Time:" Grid.Row="0" Grid.Column="2" Margin="5" VerticalAlignment="Center"/>
                                <DatePicker SelectedDate="{Binding NewReadingTime}" 
                                            Grid.Row="0" Grid.Column="3" Margin="5"/>

                                <TextBlock Text="PM2.5:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewReadingPM25, UpdateSourceTrigger=PropertyChanged}" 
                                         Grid.Row="1" Grid.Column="1" Margin="5"/>

                                <TextBlock Text="NO2 Level:" Grid.Row="1" Grid.Column="2" Margin="5" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewReadingNO2, UpdateSourceTrigger=PropertyChanged}" 
                                         Grid.Row="1" Grid.Column="3" Margin="5"/>

                                <TextBlock Text="Ozone Level:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewReadingOzone, UpdateSourceTrigger=PropertyChanged}" 
                                         Grid.Row="2" Grid.Column="1" Margin="5"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="Add Reading" Command="{Binding AddReadingCommand}" 
                                        Padding="10,5" Margin="0,0,5,0"/>
                                <Button Content="Update Selected" Command="{Binding UpdateReadingCommand}" 
                                        Padding="10,5" Margin="0,0,5,0"/>
                                <Button Content="Delete Selected" Command="{Binding DeleteReadingCommand}" 
                                        Padding="10,5"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Statistics Tab -->
            <TabItem Header="State Statistics">
                <Grid Margin="10">
                    <GroupBox Header="Air Quality State Distribution">
                        <lvc:PieChart Series="{Binding StateSeries}" 
                                      LegendPosition="Right"
                                      MinHeight="400"/>
                    </GroupBox>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
